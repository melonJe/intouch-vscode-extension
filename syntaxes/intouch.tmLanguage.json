{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "InTouch QuickScript",
  "scopeName": "source.intouch",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#operator-word" },
    { "include": "#system-variable" },
    { "include": "#number" }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.intouch",
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        {
          "name": "keyword.other.documentation.intouch",
          "match": "\\b(TODO|FIXME|HACK|NOTE|BUG|XXX)\\b"
        }
      ]
    },
    "string": {
      "name": "string.quoted.double.intouch",
      "begin": "\"",
      "end": "\"|$",
      "patterns": [
        {
          "name": "constant.character.escape.intouch",
          "match": "\\\\."
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.intouch",
          "match": "(?i)\\b(IF|THEN|ELSE|ENDIF|FOR|TO|STEP|NEXT|DIM|CALL|EXIT|RETURN|HideSelf|Show|Hide|Ack)\\b"
        }
      ]
    },
    "type": {
      "name": "storage.type.intouch",
      "match": "(?i)\\b(INTEGER|REAL|DISCRETE|MESSAGE|TIME|BOOLEAN)\\b"
    },
    "operator-word": {
      "name": "keyword.operator.intouch",
      "match": "(?i)\\b(AND|OR|NOT|XOR|MOD)\\b"
    },
    "system-variable": {
      "name": "variable.language.intouch",
      "match": "\\$[A-Za-z][A-Za-z0-9_]*"
    },
    "number": {
      "name": "constant.numeric.intouch",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  }
}
