{
  "name": "intouch-language",
  "displayName": "InTouch Support",
  "description": "Tree-sitter-powered syntax highlighting for AVEVA InTouch HMI QuickScript and Window Report exports.",
  "version": "2.0.0",
  "publisher": "melonJe",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "intouch",
    "wonderware",
    "aveva",
    "hmi",
    "scada",
    "quickscript",
    "tree-sitter"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "intouch",
        "aliases": [
          "InTouch QuickScript",
          "intouch"
        ],
        "extensions": [
          ".intouch",
          ".txt"
        ],
        "firstLine": "^\\s*(\\{|INTEGER|REAL|DISCRETE|MESSAGE|TIME|IF|THEN|WHILE|FOR|DIM|TagRead|TagWrite|\\$DateString|Window Report for|Object Type:|Application Scripts)",
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "intouch",
        "scopeName": "source.intouch",
        "path": "./syntaxes/intouch.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "intouch",
        "scopes": {
          "function.defaultLibrary": [
            "support.function.intouch"
          ],
          "variable.defaultLibrary": [
            "support.variable.intouch"
          ],
          "comment.documentation": [
            "keyword.codetag.notation.intouch",
            "comment.block.documentation.intouch"
          ]
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/melonJe/intouch-vscode-extension.git"
  },
  "dependencies": {
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build:parser": "cd tree-sitter-intouch && ./node_modules/.bin/tree-sitter generate && ./node_modules/.bin/tree-sitter build --wasm && cp tree-sitter-intouch.wasm ../out/",
    "compile": "tsc -p .",
    "vscode:prepublish": "npm run build:parser && npm run compile",
    "package": "vsce package"
  }
}
