{ InTouch QuickScript sample — exercises the major syntax features. }

{ --- Declarations --- }
DIM motorSpeed INTEGER;
DIM temperature REAL;
DIM statusText MESSAGE;
DIM motorRunning DISCRETE;

{ --- Assignments (including % tag names and tag properties) --- }
Batch%Conc = SetPoint;
motorSpeed = 1500;
temperature = 25.5;
HistTrend.ChartLength = 180;
HistTrend.Pen4 = SetPoint.TagID;

{ --- Bare commands (no parens) --- }
HideSelf;
ShowHome;              { user-defined Quickfunction }
Show "Operator help";
Hide "Conveyor";
Ack ReactLevel;
Ack $System;

{ --- IF / nested IF with ELSE + inner IF (no dedicated ELSEIF) --- }
IF Cycle == 5 OR Cycle == 6 THEN
  HorizontalMove = 0;
  VerticalMove = 0;
ENDIF;

IF Step1 == 8 THEN
  IF ProdLevel > 9000 THEN
    Step1 = 9;
  ELSE
    IF ReactLevel <= 0 THEN
      Step1 = 10;
    ENDIF;
  ENDIF;
ENDIF; {AUTO}

{ --- FOR loop with STEP --- }
FOR i = 1 TO 10 STEP 2
  TagWrite("Counter", i);
  motorSpeed = i * 100;
NEXT;

{ --- Built-in function calls --- }
statusText = StringFromReal(temperature, 2);
HTUpdateToCurrentTime( "HistTrend" );
TagWrite("Motor.Speed", motorSpeed);

{ --- Logical + arithmetic expressions --- }
IF (NOT Auto) AND (PassWord == "INTOUCH") THEN
  Auto = 1;
ENDIF;

IF $Second > 0 AND $Second < 60 THEN
  LogMessage("Heartbeat tick");
ENDIF;

{ --- Subroutine call (legacy CALL) and EXIT --- }
CALL Cleanup;
EXIT;
